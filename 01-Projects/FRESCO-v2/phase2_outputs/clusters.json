  "cross_cluster_notes": {
    "memory_measurement_incompatibility": "Clusters use different memory metrics: Stampede/Anvil include page cache (larger values), Conte uses RSS only (smaller values). This causes 6-9x systematic offsets (EXP-012 FIND-028).",
    "recommended_normalization": "Use peak_memory_fraction = peak_memory_gb / node_memory_gb for cross-site comparison. This removes hardware capacity differences but not measurement methodology differences.",
    "temporal_overlap": "Conte (2015-2017) and Stampede (2013-2018) have 2-year overlap enabling cross-validation.",
    "era_effects": "10-year span (2013-2023) shows evolution: legacy TACC_Stats → hybrid monitoring → modern cgroup-based collection.",
    "workload_differences": "Anvil GPU-centric ML/AI workloads differ from Stampede/Conte traditional HPC workloads. May affect memory usage patterns beyond measurement differences."
  },
  
  "validation_references": {
    "systematic_offsets": "EXP-012 (FIND-028): Measured 6-9x offsets between clusters",
    "calibration_study": "EXP-013 (FIND-030): Affine log-space calibration can rescue but requires target data",
    "baseline_failure": "EXP-011 (FIND-027): Cross-site memory prediction R²=-24 without normalization",
    "memory_coverage": "All clusters have >99% memory data coverage (not a missingness issue)"
  }
